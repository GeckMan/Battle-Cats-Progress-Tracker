generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}


datasource db {
  provider = "postgresql"
}

/**
 * ---------- Enums ----------
 */

enum Visibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum TreasureStatus {
  NONE
  PARTIAL
  ALL
}

enum ZombieStatus {
  NONE
  PARTIAL
  ALL
}

enum LegendProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum MilestoneCategory {
  CRAZED
  MANIC
  ADVENT
  CATCLAW
  OTHER
}

enum UnitCategory {
  NORMAL
  SPECIAL
  RARE
  SUPER_RARE
  UBER_RARE
  LEGEND_RARE
}

/**
 * ---------- Auth / Users ----------
 */

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  // For a friends-only app, you can keep email optional.
  // If you later add password reset, making email required is better.
  email        String?  @unique
  passwordHash String
  displayName  String?
  role            String    @default("USER") // USER | ADMIN
  chatMutedUntil  DateTime? // null = not muted; future timestamp = muted until then
  theme           String    @default("default") // "default" | "nerv"
  hasUnleashedCat Boolean   @default(false)
  lastActiveAt    DateTime? // updated by a lightweight heartbeat ping; drives the "online now" count
  createdAt       DateTime  @default(now())
  updatedAt    DateTime @updatedAt

  privacy PrivacySettings?

  sentFriendRequests     Friendship[] @relation("FriendRequestsSent")
  receivedFriendRequests Friendship[] @relation("FriendRequestsReceived")

  storyProgress     UserStoryProgress[]
  legendProgress    UserLegendProgress[]
  milestoneProgress UserMilestoneProgress[]
  catclawProgress   UserCatclawProgress?
  meowMedalProgress UserMeowMedal[]
  unitProgress      UserUnitProgress[]
  activities        Activity[]
  chatMessages      ChatMessage[]

  @@index([lastActiveAt])
}

model PrivacySettings {
  userId             String     @id
  profileVisibility  Visibility @default(PUBLIC)
  progressVisibility Visibility @default(FRIENDS)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
  @@index([requesterId, status])
}

/**
 * ---------- Story Catalog + Progress ----------
 */

model StoryChapter {
  id            String @id @default(cuid())
  arc           String
  chapterNumber Int
  displayName   String
  sortOrder     Int

  progress UserStoryProgress[]

  @@unique([arc, chapterNumber])
  @@index([sortOrder])
}

model UserStoryProgress {
  id             String         @id @default(cuid())
  userId         String
  storyChapterId String
  cleared        Boolean        @default(false)
  treasures      TreasureStatus @default(NONE)
  zombies        ZombieStatus   @default(NONE)
  updatedAt      DateTime       @updatedAt

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter StoryChapter @relation(fields: [storyChapterId], references: [id], onDelete: Cascade)

  @@unique([userId, storyChapterId])
  @@index([userId])
}

/**
 * ---------- Legend Catalog + Progress (Subchapter + Crown 1–4) ----------
 */

model LegendSaga {
  id          String @id @default(cuid())
  displayName String
  sortOrder   Int

  subchapters LegendSubchapter[]

  @@index([sortOrder])
}

model LegendSubchapter {
  id          String @id @default(cuid())
  sagaId      String
  displayName String
  sortOrder   Int
  stageCount  Int?   // number of stages in this subchapter (from BCData sync)
  maxCrowns   Int    @default(4) // max crowns available (1-4, from game data)

  saga     LegendSaga           @relation(fields: [sagaId], references: [id], onDelete: Cascade)
  progress UserLegendProgress[]

  @@unique([sagaId, displayName])
  @@index([sagaId, sortOrder])
}

model UserLegendProgress {
  id           String               @id @default(cuid())
  userId       String
  subchapterId String
  status       LegendProgressStatus @default(NOT_STARTED)
  crownMax     Int? // 1-4; null if unknown/not applicable
  notes        String?
  updatedAt    DateTime             @updatedAt

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subchapter LegendSubchapter @relation(fields: [subchapterId], references: [id], onDelete: Cascade)

  @@unique([userId, subchapterId])
  @@index([userId])
}

/**
 * ---------- Milestones Catalog + Progress ----------
 */

model Milestone {
  id          String            @id @default(cuid())
  category    MilestoneCategory
  displayName String
  sortOrder   Int

  progress UserMilestoneProgress[]

  @@index([category, sortOrder])
}

model UserMilestoneProgress {
  id          String   @id @default(cuid())
  userId      String
  milestoneId String
  cleared     Boolean  @default(false)
  notes       String?
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestone Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@unique([userId, milestoneId])
  @@index([userId])
}

/**
 * ---------- Catclaw (simple v1) ----------
 */

model UserCatclawProgress {
  id          String   @id @default(cuid())
  userId      String   @unique
  currentRank String?
  bestRank    String?
  notes       String?
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * ---------- Meow Medals Catalog + Progress (for later scraping/import) ----------
 */

model MeowMedal {
  id              String   @id @default(cuid())
  name            String   @unique
  requirementText String?
  description     String?
  category        String?
  sortOrder       Int?
  sourceUrl       String?
  imageFile       String?

  // NEW: used to link a medal to an auto-sync rule
  autoKey         String?  @unique

  updatedAt       DateTime @updatedAt

  earnedBy UserMeowMedal[]

  @@index([category])
}

model UserMeowMedal {
  id          String    @id @default(cuid())
  userId      String
  meowMedalId String
  earned      Boolean   @default(false)
  earnedAt    DateTime?
  updatedAt   DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  meowMedal MeowMedal @relation(fields: [meowMedalId], references: [id], onDelete: Cascade)

  @@unique([userId, meowMedalId])
  @@index([userId])
}

/**
 * ---------- Unit Collection Catalog + Progress ----------
 */

model Unit {
  id         String       @id @default(cuid())
  unitNumber Int          @unique   // game-internal unit ID (0-based, used for sprite URLs)
  name        String                 // Form 1 display name
  evolvedName String?                // Form 2 (evolved) display name
  trueName    String?                // Form 3 (true form) display name
  ultraName   String?                // Form 4 (ultra form) display name — only ~18 units have this
  category    UnitCategory
  formCount   Int          @default(3) // how many forms this unit has (2 or 3)
  sortOrder   Int                    // display order within category
  isCollab    Boolean      @default(false) // true = collab/serial-code/event-capsule unit
  source      String?                // unlock method: RARE_CAPSULE, STAGE_DROP, EVENT_CAPSULE, etc.
  setName     String?                // gacha set: "Tales of the Nekoluga", "Ultra Souls", etc.
  banners       String[]  @default([]) // all banners this unit can be pulled from (for multi-banner filtering)
  evolutionData Json?                  // { tf?: { xp, items: [{id,name,count}] }, uf?: { xp, items } }
  // true = not a real collectible cat -- e.g. the 21 "Spirit of X" entries
  // (see UNIT_NAME_OVERRIDES in scripts/sync-bcdata.ts), which exist in
  // BCData's unit table as internal representations of a summoned ability
  // certain Uber Rares use in battle (the unit summons its own "Spirit of
  // X" as part of an attack), not an independently obtainable/leveled unit
  // of their own. Excluded from every collection listing, total count, and
  // completion percentage. Confirmed 2026-07-13: before these units had
  // real names they were invisible to the app (they happened to fail a
  // placeholder-name regex check), and a user's friend confirmed that was
  // the correct behavior once the rename made them visible and inflated
  // the app's unit totals.
  excludeFromCollection Boolean @default(false)

  progress UserUnitProgress[]

  @@index([category, sortOrder])
  @@index([isCollab])
  @@index([source])
  @@index([setName])
  @@index([excludeFromCollection])
}

model UserUnitProgress {
  id        String   @id @default(cuid())
  userId    String
  unitId    String
  formLevel Int      @default(0) // 0 = not obtained, 1 = Form 1, 2 = Form 2, 3 = True Form
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([userId, unitId])
  @@index([userId])
}

/**
 * ---------- Activity Feed ----------
 */

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String   // STORY_CLEARED, LEGEND_COMPLETED, MEDAL_EARNED, MILESTONE_CLEARED, UNIT_OBTAINED, UNIT_EVOLVED, UNIT_REMOVED
  itemName  String?  // human-readable name of the item (chapter, medal, unit, etc.)
  detail    String?  // extra context: "treasures → ALL", "crown 3", "True Form"
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

/**
 * ---------- Chat / Message Board ----------
 */

model ChatMessage {
  id        String    @id @default(cuid())
  userId    String
  content   String
  createdAt DateTime  @default(now())
  // Soft delete: removed messages are hidden from the feed but the row is
  // kept for moderation accountability (who removed it, and when).
  deletedAt DateTime?
  deletedBy String? // id of the user who deleted it (author or an admin)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId])
}

/**
 * ---------- Rate Limiting ----------
 */

model RateLimit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

/**
 * ---------- Login Attempt Audit Log ----------
 * Records every login attempt (success or failure) so admins can review
 * suspicious activity. Never stores the attempted password.
 */

model LoginAttempt {
  id        String   @id @default(cuid())
  username  String // attempted username as typed, normalized lowercase
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ip, createdAt])
}

/**
 * ---------- App Metadata (generic key/value) ----------
 * Small store for facts about the app's own state that aren't tied to any
 * user — currently just the BCData version last synced, so the Units page
 * can show a real, self-updating "current to game version X" note instead
 * of a hardcoded string that silently goes stale every time new units ship
 * (bug report, 2026-07-16, bvg_tbc: the note still said "15.1.1" long after
 * newer units like Moon Lunos and Vornado had already synced in).
 */

model AppMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
